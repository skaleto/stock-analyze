[Unit]
Description=Stock Analyze monthly competition review (claude vs codex)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/stock-analyze/app
Environment=TZ=Asia/Shanghai
ExecStart=/opt/stock-analyze/venv/bin/python -m stock_analyze.cli --logs-dir /opt/stock-analyze/logs competition-monthly-review
# After OpenSpec change `enable-llm-direct-strategy-evolution`: no referee / apply step on ECS.
# Monthly strategy evolution is performed by the LLM agent on the operator's local machine
# (slash command `/monthly-strategy <agent>`), then synced back via `./scripts/sync-to-ecs.sh`.
ExecStartPost=/opt/stock-analyze/venv/bin/python -m stock_analyze.cli --logs-dir /opt/stock-analyze/logs competition-dashboard
StandardOutput=append:/opt/stock-analyze/logs/monthly-review.log
StandardError=append:/opt/stock-analyze/logs/monthly-review.err
