[Unit]
Description=Stock Analyze competition aggregator dashboard refresh
# Triggered via OnSuccess= from the four agent services (claude/codex × daily/weekly).
# Re-renders reports/competition/dashboard.html (the 3-tab claude/codex/compare view)
# so it stays in sync with the per-agent dashboards. Without this hook the aggregator
# only refreshes when scripts/sync-to-ecs.sh runs, which can leave it 24h+ stale.
# Two agents finishing back-to-back will fire two start jobs; systemd merges
# concurrent requests, and an extra render is a cheap read-only operation.
After=network-online.target
Wants=network-online.target
OnFailure=stock-analyze-pipeline-failure@%n.service

[Service]
Type=oneshot
WorkingDirectory=/opt/stock-analyze/app
Environment=TZ=Asia/Shanghai
EnvironmentFile=-/etc/stock-analyze/secrets.env
ExecStart=/opt/stock-analyze/venv/bin/python -m stock_analyze.cli --logs-dir /opt/stock-analyze/logs competition-dashboard
# After the aggregator dashboard refreshes, push the day's summary to the
# operator's Lark DM (build_daily_summary → Lark Open API). The leading `-`
# makes failure non-fatal: a Lark outage or missing credentials shouldn't
# trip the unit's OnFailure= cascade (the dashboard already succeeded).
# Failures still surface in journalctl + the script's own stderr.
ExecStartPost=-/opt/stock-analyze/app/scripts/notify-daily-summary.sh
StandardOutput=append:/opt/stock-analyze/logs/aggregate-dashboard.log
StandardError=append:/opt/stock-analyze/logs/aggregate-dashboard.err
