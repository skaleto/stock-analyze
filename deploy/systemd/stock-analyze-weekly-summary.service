[Unit]
Description=Stock Analyze consolidated weekly workflow reminder
After=network-online.target
Wants=network-online.target
OnFailure=stock-analyze-pipeline-failure@%n.service

[Service]
Type=oneshot
WorkingDirectory=/opt/stock-analyze/app
Environment=TZ=Asia/Shanghai
EnvironmentFile=-/etc/stock-analyze/secrets.env
ExecStart=/opt/stock-analyze/venv/bin/python -m stock_analyze.cli --logs-dir /opt/stock-analyze/logs notify-workflow-summary --cadence weekly --repo-root /opt/stock-analyze/app
StandardOutput=append:/opt/stock-analyze/logs/weekly-summary.log
StandardError=append:/opt/stock-analyze/logs/weekly-summary.err
